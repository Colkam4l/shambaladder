# ============================================================
# ShambaLadder — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your real values.
#   cp .env.local.example .env.local
#
# NEVER commit .env.local. It is in .gitignore.
# This file (.env.local.example) IS safe to commit.
# ============================================================


# ------------------------------------------------------------
# Neo4j Aura (Graph DB — peer benchmark intelligence)
# Get these from: https://console.neo4j.io → your instance → Connect
# ------------------------------------------------------------
NEO4J_URI=neo4j+s://XXXXXXXX.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-aura-password


# ------------------------------------------------------------
# Featherless (LLM inference — Mistral-7B explanation engine)
# Get your key from: https://featherless.ai → API Keys
# ------------------------------------------------------------
FEATHERLESS_API_KEY=your-featherless-api-key
FEATHERLESS_MODEL=mistralai/Mistral-7B-Instruct-v0.2


# ------------------------------------------------------------
# App (public — safe to expose to the browser)
# Set this to your Vercel deployment URL once deployed.
# For local dev, use http://localhost:3000
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ------------------------------------------------------------
# Notes
# ------------------------------------------------------------
# Open-Meteo (climate data) — no API key needed, free at prototype volume
# SoilGrids (soil data)    — no API key needed, GPS-based REST API
# Vercel                   — credentials are managed by the Vercel CLI / dashboard
# ------------------------------------------------------------
